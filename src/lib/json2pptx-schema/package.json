{
  "name": "json2pptx-schema",
  "version": "0.2.2",
  "description": "Schema parsing pipeline for json2pptx documents (migrate -> validate -> normalize).",
  "license": "MIT",
  "homepage": "https://json2pptx.henryge.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gezhiheng/json2pptx-editor.git",
    "directory": "src/lib/json2pptx-schema"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev:watch": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "ajv": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
